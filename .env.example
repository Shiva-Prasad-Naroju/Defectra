# Copy to .env in the repo root. Never commit .env.



# vLLM OpenAI-compatible base (no /v1 suffix). Default matches typical compose port mapping.

VLLM_BASE_URL=http://172.20.7.22:8000



# Must match vLLM --served-model-name

VLLM_MODEL=gemma4-31b



# Sampling (technical reporting: moderate temperature)

VLLM_TEMPERATURE=0.3

VLLM_MAX_TOKENS=10000



# Vision + 31B can be slow

VLLM_HTTP_TIMEOUT_S=300



# Optional Bearer token if you enable auth on vLLM later

VLLM_API_KEY=


# --- Frontend (Vite): optional ---
# For dev proxy / "Failed to fetch" fixes, see frontend/.env.example (VITE_API_PROXY_TARGET, VITE_API_BASE_URL).

