# Copy to `.env` in this folder. Never commit `.env`.
# See comments in `.env` (same keys) for what each variable does.

# --- vLLM (OpenAI-compatible server; NOT FastAPI) ---
# Point at the host port Docker publishes for vLLM (the left side of -p HOST:CONTAINER).
# Example: -p 8000:8000 → http://127.0.0.1:8000 ; -p 8001:8000 → http://127.0.0.1:8001
# Run Defectra (uvicorn) on a different port than VLLM (often 8010 vs 8000).
VLLM_BASE_URL=http://127.0.0.1:8000
VLLM_MODEL=your-model-name
VLLM_API_KEY=
VLLM_TEMPERATURE=0.3
VLLM_MAX_TOKENS=20000
VLLM_HTTP_TIMEOUT_S=300

# --- Backend tuning ---
INSPECTION_CHAT_TEMPERATURE=0.35
INSPECTION_MAX_IMAGE_MB=20
LANDING_ASSISTANT_TEMPERATURE=0.42

# --- Frontend (Vite) — proxy /api to Defectra uvicorn ---
VITE_API_PROXY_TARGET=http://127.0.0.1:8010
# VITE_API_BASE_URL=
VITE_CHAT_SCROLL_NEAR_BOTTOM_PX=100

# --- Inspection chat PDF (Puppeteer + Chromium via Node) ---
# One-time: cd backend/pdf_puppeteer && npm install
# Optional: INSPECTION_PDF_NODE_BINARY=node
# Optional: PUPPETEER_EXECUTABLE_PATH= (path to Chrome) if bundled Chromium fails
# Optional: INSPECTION_PDF_LOG_HTML=1 logs HTML before render (large logs)
INSPECTION_PDF_RENDER_TIMEOUT_S=120
