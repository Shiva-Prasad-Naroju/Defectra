# Copy to .env.development in this folder (never commit secrets).



# When FastAPI runs somewhere other than 127.0.0.1:8000 as seen from the Vite dev server process

# (e.g. WSL IP while npm run dev is on Windows), set the proxy target:

# VITE_API_PROXY_TARGET=http://172.28.123.45:8000



# Optional: browser calls FastAPI directly (skips Vite /api proxy). Use only when the browser

# can reach this URL (same machine as the browser, or LAN IP + CORS already open on FastAPI).

# VITE_API_BASE_URL=http://127.0.0.1:8000

